{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/KaraZajac/SUCCURRO/schemas/succurro.schema.json",
  "title": "SUCCURRO record schemas",
  "$defs": {
    "date": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "state": {"type": "string", "pattern": "^[a-z]{2}$"},
    "slug": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "token": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "time": {"type": "string", "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"},
    "geo": {
      "type": "object",
      "properties": {
        "lat": {"type": "number", "minimum": -90, "maximum": 90},
        "lng": {"type": "number", "minimum": -180, "maximum": 180}
      },
      "required": ["lat", "lng"],
      "additionalProperties": false
    },
    "verified": {
      "type": "object",
      "properties": {
        "on": {"$ref": "#/$defs/date"},
        "method": {"enum": ["api", "scrape", "human"]},
        "by": {"type": "string"}
      },
      "required": ["on", "method"],
      "additionalProperties": false
    },
    "address": {
      "type": "object",
      "properties": {
        "street": {"type": "string"},
        "street2": {"type": "string"},
        "city": {"type": "string"},
        "state": {"$ref": "#/$defs/state"},
        "zip": {"type": "string", "pattern": "^\\d{5}(-\\d{4})?$"}
      },
      "required": ["city", "state"],
      "additionalProperties": false
    },
    "hoursEntry": {
      "type": "object",
      "properties": {
        "days": {"type": "array", "items": {"enum": ["mon", "tue", "wed", "thu", "fri", "sat", "sun"]}, "minItems": 1},
        "open": {"$ref": "#/$defs/time"},
        "close": {"$ref": "#/$defs/time"},
        "note": {"type": "string"}
      },
      "required": ["days"],
      "additionalProperties": false
    },
    "scheduleEntry": {
      "type": "object",
      "properties": {
        "day": {"enum": ["mon", "tue", "wed", "thu", "fri", "sat", "sun"]},
        "time": {"$ref": "#/$defs/time"},
        "duration_min": {"type": "integer", "minimum": 1},
        "note": {"type": "string"}
      },
      "required": ["day", "time"],
      "additionalProperties": false
    },
    "serviceArea": {
      "type": "object",
      "properties": {
        "kind": {"enum": ["place", "county", "state", "regional", "national"]},
        "name": {"type": "string"},
        "state": {"$ref": "#/$defs/state"}
      },
      "required": ["kind"],
      "additionalProperties": false
    },
    "externalIds": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    },
    "sourceRefs": {
      "type": "array",
      "items": {"type": "string", "pattern": "^[a-z0-9-]+/[a-z0-9._-]+$"},
      "minItems": 1
    },
    "place": {
      "type": "object",
      "properties": {
        "id": {"type": "string", "pattern": "^\\d{7,10}$"},
        "slug": {"$ref": "#/$defs/slug"},
        "name": {"type": "string"},
        "state": {"$ref": "#/$defs/state"},
        "kind": {"enum": ["city", "town", "village", "borough", "cdp", "township", "municipality", "other"]},
        "county": {"type": "string"},
        "geo": {"$ref": "#/$defs/geo"},
        "aliases": {"type": "array", "items": {"type": "string"}}
      },
      "required": ["id", "slug", "name", "state", "kind", "geo"],
      "additionalProperties": false
    },
    "org": {
      "type": "object",
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z]{2}/[a-z0-9][a-z0-9-]*$"},
        "name": {"type": "string"},
        "aliases": {"type": "array", "items": {"type": "string"}},
        "categories": {"type": "array", "items": {"$ref": "#/$defs/token"}, "minItems": 1},
        "parent_org": {"type": "string"},
        "description": {"type": "string"},
        "address": {"$ref": "#/$defs/address"},
        "place": {"type": "string"},
        "geo": {"$ref": "#/$defs/geo"},
        "website": {"type": "string", "format": "uri"},
        "phone": {"type": "string"},
        "email": {"type": "string"},
        "service_area": {"$ref": "#/$defs/serviceArea"},
        "languages": {"type": "array", "items": {"type": "string", "pattern": "^[a-z]{2,3}$"}},
        "external_ids": {"$ref": "#/$defs/externalIds"},
        "provisional": {"const": true},
        "sources": {"$ref": "#/$defs/sourceRefs"},
        "verified": {"$ref": "#/$defs/verified"}
      },
      "required": ["id", "name", "categories", "sources", "verified"],
      "additionalProperties": false
    },
    "site": {
      "type": "object",
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z]{2}/[a-z0-9-]+/[a-z0-9][a-z0-9-]*$"},
        "org": {"type": "string"},
        "name": {"type": "string"},
        "aliases": {"type": "array", "items": {"type": "string"}},
        "categories": {"type": "array", "items": {"$ref": "#/$defs/token"}, "minItems": 1},
        "description": {"type": "string"},
        "address": {"$ref": "#/$defs/address"},
        "place": {"type": "string"},
        "geo": {"$ref": "#/$defs/geo"},
        "phone": {"type": "string"},
        "email": {"type": "string"},
        "website": {"type": "string", "format": "uri"},
        "hours": {"type": "array", "items": {"$ref": "#/$defs/hoursEntry"}},
        "eligibility": {"type": "string"},
        "cost": {"enum": ["free", "sliding-scale", "insurance", "varies"]},
        "accessibility": {"type": "array", "items": {"$ref": "#/$defs/token"}},
        "languages": {"type": "array", "items": {"type": "string", "pattern": "^[a-z]{2,3}$"}},
        "dv_confidential": {"const": true},
        "external_ids": {"$ref": "#/$defs/externalIds"},
        "provisional": {"const": true},
        "sources": {"$ref": "#/$defs/sourceRefs"},
        "verified": {"$ref": "#/$defs/verified"}
      },
      "required": ["id", "name", "categories", "sources", "verified"],
      "additionalProperties": false
    },
    "meeting": {
      "type": "object",
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z]{2}/[a-z0-9-]+/[a-z0-9][a-z0-9-]*$"},
        "name": {"type": "string"},
        "program": {"$ref": "#/$defs/token"},
        "categories": {"type": "array", "items": {"$ref": "#/$defs/token"}, "minItems": 1},
        "org": {"type": "string"},
        "site": {"type": "string"},
        "schedule": {"type": "array", "items": {"$ref": "#/$defs/scheduleEntry"}, "minItems": 1},
        "format": {"enum": ["in-person", "online", "hybrid"]},
        "types": {"type": "array", "items": {"$ref": "#/$defs/token"}},
        "venue": {"$ref": "#/$defs/address"},
        "venue_name": {"type": "string"},
        "place": {"type": "string"},
        "geo": {"$ref": "#/$defs/geo"},
        "url": {"type": "string", "format": "uri"},
        "conference_url": {"type": "string", "format": "uri"},
        "notes": {"type": "string"},
        "languages": {"type": "array", "items": {"type": "string", "pattern": "^[a-z]{2,3}$"}},
        "external_ids": {"$ref": "#/$defs/externalIds"},
        "provisional": {"const": true},
        "sources": {"$ref": "#/$defs/sourceRefs"},
        "verified": {"$ref": "#/$defs/verified"}
      },
      "required": ["id", "name", "program", "categories", "schedule", "format", "sources", "verified"],
      "additionalProperties": false
    },
    "source": {
      "type": "object",
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9-]+/[a-z0-9._-]+$"},
        "kind": {"enum": ["directory", "api-feed", "dataset", "org-website", "registry"]},
        "publisher": {"type": "string"},
        "title": {"type": "string"},
        "url": {"type": ["string", "null"]},
        "archive_url": {"type": "string"},
        "published_on": {"$ref": "#/$defs/date"},
        "retrieved_on": {"$ref": "#/$defs/date"},
        "tier": {"enum": ["primary", "secondary", "tertiary"]},
        "content_sha256": {"type": ["string", "null"]},
        "notes": {"type": "string"}
      },
      "required": ["id", "kind", "publisher", "title", "retrieved_on", "tier"],
      "additionalProperties": false,
      "if": {"properties": {"url": {"const": null}}},
      "then": {"required": ["notes"]}
    },
    "taxonomyEntry": {
      "type": "object",
      "properties": {
        "id": {"$ref": "#/$defs/token"},
        "parent": {"$ref": "#/$defs/token"},
        "label": {"type": "string"},
        "superseded_by": {"$ref": "#/$defs/token"}
      },
      "required": ["id", "label"],
      "additionalProperties": false
    }
  }
}
