---
import Base from "../../layouts/Base.astro";
import {
  servedPlaces, placesFor, sitesFor, meetingsFor,
  taxonomyIndex, label, STATE_NAMES, sourceIndex,
} from "../../lib/data.js";

export function getStaticPaths() {
  return servedPlaces().map(({ state, slug }) => ({ params: { state, place: slug } }));
}
const { state, place } = Astro.params;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const placeRec = placesFor(state).find((p) => p.slug === place);
const stateName = STATE_NAMES[state] || state.toUpperCase();
const placeName =
  place === "online" ? `Online (${stateName})`
  : place === "unknown" ? `${stateName} (location unlisted)`
  : placeRec?.name || place.replace(/-/g, " ");

const sources = sourceIndex();
const attribution = (rec) => {
  const s = sources.get((rec.sources || [])[0]);
  if (!s) return null;
  return { name: s.publisher, url: s.url || s.archive_url };
};
const mapsUrl = (rec) => {
  if (rec.geo) return `https://www.google.com/maps/search/?api=1&query=${rec.geo.lat},${rec.geo.lng}`;
  const a = rec.address || rec.venue;
  if (a?.street && a?.city) {
    return `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(
      `${a.street}, ${a.city}, ${(a.state || state).toUpperCase()} ${a.zip || ""}`)}`;
  }
  return null;
};

const sites = sitesFor(state, place);
const meetings = meetingsFor(state, place);

// group sites by root category
const tax = taxonomyIndex();
const rootOf = (token) => {
  let t = tax.get(token);
  while (t?.parent) t = tax.get(t.parent);
  return t?.id || token;
};
const groups = new Map();
for (const s of sites) {
  const root = rootOf((s.categories || [])[0] || "other");
  if (!groups.has(root)) groups.set(root, []);
  groups.get(root).push(s);
}
const groupOrder = [...groups.keys()].sort((a, b) => label(a).localeCompare(label(b)));

const DAY_LABELS = { mon: "Mon", tue: "Tue", wed: "Wed", thu: "Thu", fri: "Fri", sat: "Sat", sun: "Sun" };
const PROGRAMS = { aa: "AA", na: "NA", "al-anon": "Al-Anon", smart: "SMART Recovery", nami: "NAMI" };
// standard Meeting Guide / BMLT type codes -> readable labels (unknown codes hidden)
const TYPE_LABELS = {
  o: "Open", c: "Closed", d: "Discussion", sp: "Speaker", b: "Big Book",
  bb: "Big Book", st: "Step study", "12x12": "Steps & Traditions", tr: "Tradition study",
  m: "Men", w: "Women", g: "LGBTQ+", l: "LGBTQ+", t: "Transgender", yp: "Young people",
  y: "Young people", s: "Spanish", es: "Spanish", en: "English", fr: "French",
  beg: "Beginners", ne: "Newcomer", jt: "Just for Today", med: "Meditation",
  can: "Candlelight", cf: "Child-friendly", x: "Wheelchair accessible",
  wc: "Wheelchair accessible", ba: "Babysitting", var: "Format varies",
  lit: "Literature study", "as-bi": "ASL available", asl: "ASL available",
  onl: "Online", hyb: "Hybrid", vm: "Virtual", tc: "Temporarily online",
};
const typeChips = (m) =>
  (m.types || []).map((t) => TYPE_LABELS[t]).filter(Boolean).slice(0, 5);
const fmtSchedule = (m) =>
  (m.schedule || [])
    .map((e) => `${DAY_LABELS[e.day] || e.day} ${e.time}`)
    .join(", ");
const meetingsByProgram = new Map();
for (const m of meetings) {
  const prog = PROGRAMS[m.program] || m.program.toUpperCase();
  if (!meetingsByProgram.has(prog)) meetingsByProgram.set(prog, []);
  meetingsByProgram.get(prog).push(m);
}
const hoursText = (h) =>
  (h || []).map((e) => `${e.days.map((d) => DAY_LABELS[d] || d).join("/")} ${e.open}–${e.close}`).join(" · ");
---
<Base title={`Help in ${placeName}, ${stateName} — SUCCURRO`}
      description={`Food, shelter, treatment, recovery meetings, and support services in ${placeName}, ${stateName}.`}>
  <p class="meta"><a href={`${base}/${state}`}>{stateName}</a> →</p>
  <h1>Help in {placeName}</h1>
  <p class="meta">
    {sites.length > 0 && `${sites.length} service location${sites.length === 1 ? "" : "s"}`}
    {sites.length > 0 && meetings.length > 0 && " · "}
    {meetings.length > 0 && `${meetings.length} recurring meeting${meetings.length === 1 ? "" : "s"}`}
  </p>

  {groupOrder.map((root) => (
    <>
      <h2 id={root}>{label(root)}</h2>
      {groups.get(root).sort((a, b) => a.name.localeCompare(b.name)).map((s) => (
        <div class="card">
          <h3>{s.website ? <a href={s.website}>{s.name}</a> : s.name}</h3>
          <div class="meta">
            {(s.categories || []).map((c) => <span class="chip">{label(c)}</span>)}
            {s.cost === "free" && <span class="chip">free</span>}
            {s.cost === "sliding-scale" && <span class="chip">sliding-scale fees</span>}
          </div>
          <div class="meta">
            {s.address?.street && `${s.address.street}, `}{s.address?.city}
            {s.phone && ` · ${s.phone}`}
          </div>
          {s.hours && <div class="meta">{hoursText(s.hours)}</div>}
          {s.description && <div class="meta">{s.description}</div>}
          {s.eligibility && <div class="meta">Eligibility: {s.eligibility}</div>}
          <div class="meta">
            {mapsUrl(s) && <a href={mapsUrl(s)}>directions</a>}
            {attribution(s) && (
              <>
                {mapsUrl(s) && " · "}
                <span>
                  via {attribution(s).url
                    ? <a href={attribution(s).url}>{attribution(s).name}</a>
                    : attribution(s).name},
                  verified {s.verified?.on}
                </span>
              </>
            )}
          </div>
        </div>
      ))}
    </>
  ))}

  {meetings.length > 0 && <h2 id="meetings">Recovery &amp; support meetings</h2>}
  {[...meetingsByProgram.keys()].sort().map((prog) => (
    <>
      <h3>{prog} meetings</h3>
      {meetingsByProgram.get(prog)
        .sort((a, b) => a.name.localeCompare(b.name))
        .map((m) => (
          <div class="card">
            <h3>{m.url ? <a href={m.url}>{m.name}</a> : m.name}</h3>
            <div class="meta">
              {fmtSchedule(m)} · {m.format}
              {m.venue_name && ` · ${m.venue_name}`}
              {typeChips(m).map((t) => <span class="chip">{t}</span>)}
            </div>
            <div class="meta">
              {m.venue?.street && `${m.venue.street}, `}{m.venue?.city}
              {m.conference_url && <a href={m.conference_url}> join online</a>}
              {mapsUrl(m) && <> · <a href={mapsUrl(m)}>directions</a></>}
              {attribution(m) && (
                <> · via {attribution(m).url
                  ? <a href={attribution(m).url}>{attribution(m).name}</a>
                  : attribution(m).name}</>
              )}
            </div>
          </div>
        ))}
    </>
  ))}

  <p class="meta">
    Every listing is sourced and dated — see
    <a href="https://github.com/KaraZajac/SUCCURRO">the dataset</a> to verify or
    submit corrections. Call ahead when you can: hours and locations change.
  </p>
</Base>
